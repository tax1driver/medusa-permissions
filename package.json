{
    "name": "medusa-permissions",
    "version": "0.0.773",
    "description": "A starter for Medusa plugins.",
    "author": "Medusa (https://medusajs.com)",
    "license": "MIT",
    "files": [
        ".medusa/server"
    ],
    "exports": {
        "./package.json": "./package.json",
        "./workflows": "./.medusa/server/src/workflows/index.js",
        "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
        "./modules/*": "./.medusa/server/src/modules/*/index.js",
        "./providers/*": "./.medusa/server/src/providers/*/index.js",
        "./actors/*": "./.medusa/server/src/actors/*/index.js",
        "./permissions/*": "./.medusa/server/src/permissions/*/index.js",
        "./permissions/*/middlewares": "./.medusa/server/src/permissions/*/middlewares/index.js",
        "./middlewares/*": "./.medusa/server/src/middlewares/*/index.js",
        "./utils/*": "./.medusa/server/src/utils/*.js",
        "./*": "./.medusa/server/src/*.js",
        "./admin": {
            "import": "./.medusa/server/src/admin/index.mjs",
            "require": "./.medusa/server/src/admin/index.js",
            "default": "./.medusa/server/src/admin/index.js"
        },
        ".": {
            "import": "./.medusa/server/src/index.mjs",
            "require": "./.medusa/server/src/index.js",
            "default": "./.medusa/server/src/index.js"
        }
    },
    "keywords": [
        "medusa",
        "plugin",
        "medusa-plugin-other",
        "medusa-plugin",
        "medusa-v2"
    ],
    "scripts": {
        "build": "medusa plugin:build",
        "dev": "medusa plugin:develop",
        "dev:publish": "yarn version patch && medusa plugin:publish",
        "prepublishOnly": "medusa plugin:build",
        "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
        "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
        "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
    },
    "devDependencies": {
        "@medusajs/admin-sdk": "^2.13.0",
        "@medusajs/cli": "^2.13.0",
        "@medusajs/framework": "^2.13.0",
        "@medusajs/icons": "^2.13.0",
        "@medusajs/medusa": "^2.13.0",
        "@medusajs/test-utils": "^2.13.0",
        "@medusajs/ui": "4.0.25",
        "@swc/core": "^1.7.28",
        "@swc/jest": "^0.2.39",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^20.0.0",
        "@types/react": "^18.3.2",
        "@types/react-dom": "^18.2.25",
        "@uiw/react-json-view": "^2.0.0-alpha.41",
        "date-fns": "^4.1.0",
        "jest": "^30.2.0",
        "lexical": "^0.19.0",
        "lodash": "^4.17.23",
        "prop-types": "^15.8.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "recharts": "^3.7.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.2",
        "vite": "^5.2.11",
        "yalc": "^1.0.0-pre.53"
    },
    "peerDependencies": {
        "@medusajs/admin-sdk": "^2.13.0",
        "@medusajs/cli": "^2.13.0",
        "@medusajs/framework": "^2.13.0",
        "@medusajs/icons": "^2.13.0",
        "@medusajs/medusa": "^2.13.0",
        "@medusajs/test-utils": "^2.13.0",
        "@medusajs/ui": "4.0.25"
    },
    "engines": {
        "node": ">=20"
    },
    "packageManager": "yarn@4.12.0",
    "dependencies": {
        "react-colorful": "^5.6.1"
    }
}
